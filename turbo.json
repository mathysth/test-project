{
  "$schema": "https://turbo.build/schema.json",
  "version": "1",
  "globalDependencies": ["**/tsconfig.json", ".eslintrc.json", ".prettierrc.json"],
  "globalEnv": ["NODE_ENV"],
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "dependsOn": ["^build"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": [],
      "dependsOn": []
    }
  }
}
